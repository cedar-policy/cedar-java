      "Setting": {
        "memberOfTypes": ["Project", "Organization"]
      },
      "Integration": {
        "memberOfTypes": ["Project"],
        "shape": {
          "type": "Record",
          "attributes": {
            "provider": { "type": "String" },
            "enabled": { "type": "Boolean" }
          }
        }
      },
      "Pipeline": {
        "memberOfTypes": ["Project"],
        "shape": {
          "type": "Record",
          "attributes": {
            "status": { "type": "String" }
          }
        }
      },
      "Environment": {
        "memberOfTypes": ["Project"],
        "shape": {
          "type": "Record",
          "attributes": {
            "tier": { "type": "String" },
            "locked": { "type": "Boolean" }
